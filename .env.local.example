# --- 필수 API 키 ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
FAL_KEY=...

# --- Vercel Blob (Vercel 배포 시 필수, 로컬 dev에서 업로드 테스트하려면도 필요) ---
# Vercel 대시보드 → Storage → Create → Blob 만들면 프로젝트에 자동 주입됨.
# 로컬에서는 `vercel env pull .env.local` 로 받아오기.
BLOB_READ_WRITE_TOKEN=

# --- 옵션 ---
# FAL_VIDEO_MODEL=fal-ai/bytedance/seedance/v1/lite/image-to-video
# FAL_PRICE_PER_SEC_KRW=100
# MAX_BUDGET_KRW=10000
# MAX_SCENES=4
# IMAGE_HOST_MODE=data_uri
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- 리뷰 단계 건너뛰기 (자동 진행) ---
# SKIP_STORY_REVIEW=true
# SKIP_CAST_REVIEW=true
# SKIP_SCENES_REVIEW=true
# SKIP_KEYFRAME_REVIEW=true
